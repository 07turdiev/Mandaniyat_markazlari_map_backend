[Unit]
Description=Markazlar Backend (Gunicorn)
After=network.target

[Service]
User=markaz
Group=markaz
WorkingDirectory=/home/markaz/markazlar_map/back
Environment="DJANGO_SETTINGS_MODULE=config.settings_prod"
ExecStart=/home/markaz/markazlar_map/back/venv/bin/gunicorn config.wsgi:application -c /home/markaz/markazlar_map/back/deploy/gunicorn.conf.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
